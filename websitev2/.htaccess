# Environment Variables
SetEnv OPENAI_API_KEY 'YOUR_API_KEY_HERE'

# Deny access to sensitive files
<FilesMatch "\.(log|txt)$">
    Order Allow,Deny
    Deny from all
</FilesMatch>

# Allow system-prompt.txt to be read by PHP (server-side only)
<Files "system-prompt.txt">
    Order Allow,Deny
    Deny from all
</Files>

# Block access to .htaccess itself
<Files ".htaccess">
    Order Allow,Deny
    Deny from all
</Files>

# Block access to rate limit directory
<IfModule mod_rewrite.c>
    RewriteEngine On
    RewriteRule ^rate_limits/ - [F,L]
</IfModule>
